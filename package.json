{
  "name": "onpurpose",
  "version": "2.0.0",
  "description": "OnPurpose — Book People, Not Places. A human services marketplace.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "audit": "node self-learning-hotfix-engine.js",
    "autonomous": "node run-autonomous-system.js",
    "production": "node productionAutonomousEngine.js",
    "agent": "node fullAutonomousAgent.js",
    "multi-agent": "node orchestrator.js",
    "self-improving": "node selfImprovingOrchestrator.js",
    "persistent-memory": "node persistentMemoryOrchestrator.js",
    "marketing": "node runMarketingDemo.js",
    "social-bot": "node runSocialBotDemo.js",
    "social": "node runSocialBot.js",
    "safe-social": "node safeSocialBot.js",
    "enhanced-social": "node runEnhancedSocialBot.js",
    "video-engine": "node runVideoEngineDemo.js",
    "viral-video": "node runViralVideoDemo.js",
    "ultimate-viral": "node runUltimateViralDemo.js",
    "social-posters": "node runSocialMediaPosters.js",
    "viral-workflow": "node completeViralWorkflow.js",
    "viral-scheduler": "node automatedViralScheduler.js",
    "cron-viral": "node cronViralScheduler.js",
    "guard": "node deploymentGuard.js",
    "dashboard": "node intelligenceDashboardAPI.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "generate:secrets": "node -e \"const c=require('crypto');console.log('JWT_SECRET='+c.randomBytes(64).toString('hex'));console.log('REFRESH_TOKEN_SECRET='+c.randomBytes(64).toString('hex'));console.log('BCRYPT_PEPPER='+c.randomBytes(32).toString('hex'));console.log('QR_SECRET='+c.randomBytes(32).toString('hex'));\"",
    "icons": "node create-placeholders.js",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap sync ios && npx cap open ios",
    "cap:android": "npx cap sync android && npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android",
    "mobile:build": "npx cap sync && echo 'Sync complete. Open Xcode or Android Studio to build.'",
    "protect:mobile": "node protect-mobile-platform.js",
    "hotfix": "node hot-fix-system.js",
    "verify:platform": "node protect-mobile-platform.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@octokit/rest": "^20.1.2",
    "@stripe/stripe-js": "^3.4.0",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "connect-ensure-login": "^0.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "crypto-browserify": "^3.12.0",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "memorystore": "^1.6.7",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.7",
    "passport": "^0.6.0",
    "passport-local": "^1.0.0",
    "path-browserify": "^1.0.1",
    "playwright": "^1.40.1",
    "puppeteer": "^21.6.1",
    "resend": "^3.2.0",
    "sequelize": "^6.35.0",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6",
    "stream-browserify": "^3.0.0",
    "stripe": "^14.9.0",
    "twilio": "^4.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "marketplace",
    "services",
    "booking",
    "onpurpose"
  ],
  "author": "OnPurpose Inc.",
  "license": "UNLICENSED",
  "private": true
}
