{
  "name": "onpurpose",
  "version": "2.0.0",
  "description": "OnPurpose — Book People, Not Places. A human services marketplace.",
  "main": "server.js",
  "scripts": {
    "start": "npx sequelize-cli db:migrate && node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "generate:secrets": "node -e \"const c=require('crypto');console.log('JWT_SECRET='+c.randomBytes(64).toString('hex'));console.log('REFRESH_TOKEN_SECRET='+c.randomBytes(64).toString('hex'));console.log('BCRYPT_PEPPER='+c.randomBytes(32).toString('hex'));console.log('QR_SECRET='+c.randomBytes(32).toString('hex'));\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "resend": "^2.0.0",
    "sequelize": "^6.35.2",
    "sqlite3": "^5.1.6",
    "stripe": "^14.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "marketplace",
    "services",
    "booking",
    "onpurpose"
  ],
  "author": "OnPurpose Inc.",
  "license": "UNLICENSED",
  "private": true
}
