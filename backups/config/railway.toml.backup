# ⚠️ LOCKED CONFIG — DO NOT CHANGE OR DELETE THIS FILE ⚠️
# Server start command and health check path are critical.
# Last verified working: Mar 31 2026

[build]
builder = "nixpacks"

[deploy]
startCommand = "node server.js"
healthcheckPath = "/health"
healthcheckTimeout = 300
restartPolicyType = "on_failure"
restartPolicyMaxRetries = 10
