{
  "expo": {
    "name": "OnPurpose",
    "slug": "onpurpose",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1a2744",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.onpurpose.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a2744"
      },
      "package": "com.onpurpose.app"
    },
    "scheme": "onpurpose",
    "plugins": ["expo-router", "expo-font"]
  }
}
