{
  "expo": {
    "name": "OnPurpose",
    "slug": "onpurpose",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1a2744",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.onpurpose.app"
    },
    "android": {
      "package": "com.onpurpose.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "scheme": "onpurpose",
    "plugins": ["expo-router"]
  }
}
